<UserControl x:Class="CameraViewer.Views.StreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource AccentBrush}"
                BorderThickness="0"
                Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Live Stream"
                           Style="{StaticResource SectionHeader}"
                           Margin="0"/>

                <Button Grid.Column="1"
                        Command="{Binding DataContext.StartAcquisitionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource AccentButton}"
                        Padding="10,3"
                        FontSize="11"
                        Margin="0,0,4,0">
                    Start
                </Button>
                <Button Grid.Column="2"
                        Command="{Binding DataContext.StopAcquisitionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        Style="{StaticResource DangerButton}"
                        Padding="10,3"
                        FontSize="11">
                    Stop
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                BorderBrush="Transparent"
                BorderThickness="0"
                Background="#121218">
            <Grid>
                <Image Source="{Binding Bitmap}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       SnapsToDevicePixels="True"/>

                <TextBlock Text="No signal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource DividerBrush}"
                           FontSize="24"
                           Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource DividerBrush}"
                BorderThickness="0"
                Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Style="{StaticResource MutedText}">
                    <Run Text="FPS: "/>
                    <Run Text="{Binding Fps, StringFormat=F1}"/>
                </TextBlock>

                <TextBlock Grid.Column="2"
                           Text="{Binding Resolution}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
