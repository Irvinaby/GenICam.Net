<UserControl x:Class="CameraViewer.Views.StreamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CameraViewer.ViewModels"
             Background="#1E1E2E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header strip -->
        <Border Grid.Row="0"
                Background="#2A2A3E"
                BorderBrush="#44445A" BorderThickness="1,1,1,0"
                CornerRadius="4,4,0,0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Live Stream"
                           Style="{StaticResource SectionHeader}" Margin="0"/>

                <Button Grid.Column="1"
                        Command="{Binding StartCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="8,3" FontSize="11"
                        Margin="0,0,4,0">
                    ▶ Start
                </Button>
                <Button Grid.Column="2"
                        Command="{Binding StopCommand}"
                        Style="{StaticResource DangerButton}"
                        Padding="8,3" FontSize="11">
                    ■ Stop
                </Button>
            </Grid>
        </Border>

        <!-- Image viewport -->
        <Border Grid.Row="1"
                BorderBrush="#44445A" BorderThickness="1,0,1,0"
                Background="#121218">
            <Grid>
                <!-- Image rendered from WriteableBitmap -->
                <Image Source="{Binding Bitmap}"
                       Stretch="Uniform"
                       RenderOptions.BitmapScalingMode="NearestNeighbor"
                       SnapsToDevicePixels="True"/>

                <!-- Placeholder when not streaming -->
                <TextBlock Text="No signal"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="#44445A"
                           FontSize="24"
                           Visibility="{Binding IsStreaming, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}"/>
            </Grid>
        </Border>

        <!-- Status footer -->
        <Border Grid.Row="2"
                Background="#2A2A3E"
                BorderBrush="#44445A" BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4" Padding="8,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="{Binding StatusText}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Margin="16,0"
                           Style="{StaticResource MutedText}">
                    <Run Text="FPS: "/>
                    <Run Text="{Binding Fps, StringFormat=F1}"/>
                </TextBlock>

                <TextBlock Grid.Column="2"
                           Text="{Binding Resolution}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

    </Grid>
</UserControl>
