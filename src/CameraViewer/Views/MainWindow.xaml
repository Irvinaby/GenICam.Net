<Window x:Class="CameraViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:views="clr-namespace:CameraViewer.Views"
        Title="{Binding Title}"
        Width="1400" Height="860"
        MinWidth="900" MinHeight="600"
        WindowStyle="None"
        ResizeMode="CanResize"
        BorderThickness="0"
        Icon="/Assets/AppIcon.ico">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="44"
                            ResizeBorderThickness="0"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CameraVm.DiscoverCommand}"/>
    </Window.InputBindings>

    <DockPanel Background="{StaticResource BackgroundBrush}">
        <Border DockPanel.Dock="Top"
                Height="44"
                Background="{StaticResource ChromeBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,0"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Image Source="/Assets/AppIcon.ico"
                           Width="24"
                           Height="24"
                           Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Camera Viewer"
                                   FontSize="14"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding ConnectionStatus}"
                                   Style="{StaticResource MutedText}"
                                   Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="0,0,8,0"
                            shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource IconButton}"
                            Click="Minimize_Click"
                            ToolTip="Minimize"
                            Content="_"/>
                    <Button x:Name="MaxRestoreButton"
                            Style="{StaticResource IconButton}"
                            Click="MaxRestore_Click"
                            ToolTip="Maximize"
                            Content="[]"/>
                    <Button Style="{StaticResource CloseButton}"
                            Click="Close_Click"
                            ToolTip="Close"
                            Content="X"/>
                </StackPanel>
            </Grid>
        </Border>

        <StatusBar DockPanel.Dock="Bottom"
                   Background="{StaticResource SurfaceBrush}"
                   Foreground="{StaticResource MutedForegroundBrush}"
                   BorderBrush="{StaticResource BorderBrush}"
                   BorderThickness="0,0,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding ConnectionStatus}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StreamVm.StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding StreamVm.Resolution}"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Background="{StaticResource BackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="0"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="120" MaxHeight="280"/>
                    <RowDefinition Height="0"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <views:CameraListView Grid.Row="0"
                                      DataContext="{Binding CameraVm}"
                                      Margin="0"/>

                <GridSplitter Grid.Row="1" Height="0"
                              HorizontalAlignment="Stretch"
                              Background="{StaticResource BackgroundBrush}"
                              BorderThickness="0"/>

                <views:NodeTreeView Grid.Row="2"
                                    DataContext="{Binding NodeTreeVm}"
                                    Margin="0"/>
            </Grid>

            <GridSplitter Grid.Column="1" Width="0"
                          HorizontalAlignment="Stretch"
                          Background="{StaticResource BackgroundBrush}"
                          BorderThickness="0"/>

            <views:StreamView Grid.Column="2"
                              DataContext="{Binding StreamVm}"
                              Margin="0"/>
        </Grid>
    </DockPanel>
</Window>
