<Window x:Class="CameraViewer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CameraViewer.Views"
        xmlns:vm="clr-namespace:CameraViewer.ViewModels"
        Title="{Binding Title}"
        Width="1400" Height="860"
        MinWidth="900" MinHeight="600">

    <Window.InputBindings>
        <KeyBinding Key="F5" Command="{Binding CameraVm.DiscoverCommand}"/>
    </Window.InputBindings>

    <DockPanel>

        <!-- ── Menu bar ─────────────────────────────────────────── -->
        <Menu DockPanel.Dock="Top"
              Background="#2A2A3E" Foreground="#E0E0F0"
              BorderBrush="#44445A" BorderThickness="0,0,0,1">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_Camera">
                <MenuItem Header="_Discover (F5)"
                          Command="{Binding CameraVm.DiscoverCommand}"/>
                <MenuItem Header="_Connect"
                          Command="{Binding CameraVm.ConnectCommand}"/>
            </MenuItem>
            <MenuItem Header="_Acquisition">
                <MenuItem Header="_Start"
                          Command="{Binding StartAcquisitionCommand}"/>
                <MenuItem Header="S_top"
                          Command="{Binding StopAcquisitionCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ── Toolbar ──────────────────────────────────────────── -->
        <ToolBarTray DockPanel.Dock="Top"
                     Background="#2A2A3E">
            <ToolBar Background="#2A2A3E" Band="0" BandIndex="0">
                <Button Command="{Binding CameraVm.DiscoverCommand}"
                        ToolTip="Discover cameras (F5)"
                        Padding="8,4">🔍 Discover</Button>
                <Button Command="{Binding CameraVm.ConnectCommand}"
                        ToolTip="Connect to selected camera"
                        Padding="8,4" Margin="4,0,0,0">⚡ Connect</Button>
                <Separator/>
                <Button Command="{Binding StartAcquisitionCommand}"
                        Style="{StaticResource AccentButton}"
                        ToolTip="Start image acquisition"
                        Padding="8,4">▶ Start</Button>
                <Button Command="{Binding StopAcquisitionCommand}"
                        Style="{StaticResource DangerButton}"
                        ToolTip="Stop acquisition"
                        Padding="8,4" Margin="4,0,0,0">■ Stop</Button>
            </ToolBar>
        </ToolBarTray>

        <!-- ── Status bar ───────────────────────────────────────── -->
        <StatusBar DockPanel.Dock="Bottom"
                   Background="#2A2A3E" Foreground="#9090A8"
                   BorderBrush="#44445A" BorderThickness="0,1,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding ConnectionStatus}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding StreamVm.StatusText}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="{Binding StreamVm.Resolution}"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main content ─────────────────────────────────────── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" MinWidth="220"/>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="*" MinWidth="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: camera list + node tree -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MinHeight="120" MaxHeight="280"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <views:CameraListView Grid.Row="0"
                                      DataContext="{Binding CameraVm}"
                                      Margin="4,4,2,0"/>

                <GridSplitter Grid.Row="1" Height="4"
                              HorizontalAlignment="Stretch"
                              Background="#44445A"/>

                <views:NodeTreeView Grid.Row="2"
                                    DataContext="{Binding NodeTreeVm}"
                                    Margin="4,0,2,4"/>
            </Grid>

            <!-- Vertical splitter -->
            <GridSplitter Grid.Column="1" Width="4"
                          HorizontalAlignment="Stretch"
                          Background="#44445A"/>

            <!-- Right panel: image stream -->
            <views:StreamView Grid.Column="2"
                              DataContext="{Binding StreamVm}"
                              Margin="2,4,4,4"/>
        </Grid>

    </DockPanel>
</Window>
