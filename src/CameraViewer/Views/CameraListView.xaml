<UserControl x:Class="CameraViewer.Views.CameraListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:CameraViewer.ViewModels">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="#2A2A3E"
                BorderBrush="#44445A" BorderThickness="1,1,1,0"
                CornerRadius="4,4,0,0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="Cameras"
                           Style="{StaticResource SectionHeader}"
                           Margin="0"/>
                <Button Grid.Column="1"
                        Command="{Binding DiscoverCommand}"
                        Padding="6,2"
                        FontSize="11"
                        ToolTip="Discover cameras on the network">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔍" Margin="0,0,4,0"/>
                        <TextBlock Text="Discover"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Camera list -->
        <ListBox Grid.Row="1"
                 ItemsSource="{Binding Cameras}"
                 SelectedItem="{Binding SelectedCamera}"
                 BorderThickness="1,0,1,0"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock FontWeight="SemiBold">
                            <Run Text="{Binding ManufacturerName, Mode=OneWay}"/>
                            <Run Text=" "/>
                            <Run Text="{Binding ModelName, Mode=OneWay}"/>
                        </TextBlock>
                        <TextBlock Style="{StaticResource MutedText}">
                            <Run Text="IP: "/>
                            <Run Text="{Binding IpAddress, Mode=OneWay}"/>
                            <Run Text="  SN: "/>
                            <Run Text="{Binding SerialNumber, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Footer: status + connect button -->
        <Border Grid.Row="2"
                Background="#2A2A3E"
                BorderBrush="#44445A" BorderThickness="1,0,1,1"
                CornerRadius="0,0,4,4" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Style="{StaticResource MutedText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
                <Button Grid.Column="1"
                        Command="{Binding ConnectCommand}"
                        Style="{StaticResource AccentButton}"
                        Padding="8,3" FontSize="11">
                    ⚡ Connect
                </Button>
            </Grid>
        </Border>

        <!-- Busy overlay -->
        <Border Grid.Row="0" Grid.RowSpan="3"
                Background="#80000000"
                Visibility="{Binding IsDiscovering, Converter={StaticResource BoolToVisibility}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="Discovering…" Foreground="White" FontSize="14" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
